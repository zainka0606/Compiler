mod Core;

# Core utilities.

fn push(array, value) {
  return __array_push(array, value);
}

fn pop(array) {
  return __array_pop(array);
}

fn stringConcat(lhs, rhs) {
  return __string_concat(lhs, rhs);
}

fn sign(x) {
  return x > 0 ? 1 : (x < 0 ? -1 : 0);
}

fn clamp(value, low, high) {
  return value < low ? low : (value > high ? high : value);
}

fn lerp(a, b, t) {
  return a + (b - a) * t;
}

fn inverseLerp(a, b, value) {
  return a == b ? 0 : (value - a) / (b - a);
}

fn mapRange(value, in_min, in_max, out_min, out_max) {
  let t = clamp(inverseLerp(in_min, in_max, value), 0, 1);
  return lerp(out_min, out_max, t);
}

fn approxEqual(a, b, epsilon) {
  return abs(a - b) <= epsilon;
}

fn sumValues(values) {
  let total = 0;
  for (let i = 0; i < len(values); i += 1) {
    total += values[i];
  }
  return total;
}

fn productValues(values) {
  let total = 1;
  for (let i = 0; i < len(values); i += 1) {
    total *= values[i];
  }
  return total;
}

fn average(values) {
  return len(values) == 0 ? 0 : sumValues(values) / len(values);
}

fn repeatText(text, count) {
  let out = "";
  for (let i = 0; i < count; i += 1) {
    out = stringConcat(out, text);
  }
  return out;
}

fn joinText(parts, separator) {
  if (len(parts) == 0) {
    return "";
  }
  let out = "";
  for (let i = 0; i < len(parts); i += 1) {
    if (i > 0) {
      out = stringConcat(out, separator);
    }
    out = stringConcat(out, parts[i]);
  }
  return out;
}
